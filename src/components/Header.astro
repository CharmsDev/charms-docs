---
import LanguageSelect from '@astrojs/starlight/components/LanguageSelect.astro';
import Search from '@astrojs/starlight/components/Search.astro';
import SiteTitle from '@astrojs/starlight/components/SiteTitle.astro';
import SocialIcons from '@astrojs/starlight/components/SocialIcons.astro';
import ThemeSelect from '@astrojs/starlight/components/ThemeSelect.astro';
---

<!-- Header override: keep Starlight defaults, inject BOS tagline beside SiteTitle -->
<div class="sl-flex header">
  <div class="header-left">
    <SiteTitle {...(Astro.props as any)} />

    <a href="https://bitcoinos.build/" target="_blank" rel="noopener noreferrer" class="designed-for-bos" aria-label="Designed for BOS - bitcoinos.build">
