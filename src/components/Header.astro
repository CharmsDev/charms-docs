        </defs>
      </svg>
    </a>
  </div>

  <div class="header-right">
    <div class="social-icons sl-hidden md:sl-flex">
      <SocialIcons {...(Astro.props as any)} />
    </div>
    <LanguageSelect {...(Astro.props as any)} />
    <div class="spacer" aria-hidden="true"></div>
    <div class="search-wrap">
      <Search {...(Astro.props as any)} />
    </div>
    <ThemeSelect {...(Astro.props as any)} />
  </div>
</div>

<style>
  .header {
    gap: var(--sl-nav-gap);
    justify-content: space-between;
    align-items: center;
    height: 100%;
    min-height: 72px; /* accommodate larger logo */
    padding: 0 0.5rem;
    position: relative;
    z-index: 1;
    /* Ensure Charms logo prominence (double size) */
    --sl-logo-height: 64px;
  }

  .header-left { display: inline-flex; align-items: center; min-width: 0; flex: 0 1 auto; gap: 0.5rem; }
  .header-right { display: inline-flex; align-items: center; gap: 0.75rem; flex: 1 1 auto; width: 100%; }
  .spacer { flex: 1 1 auto; }
  .search-wrap { display: inline-flex; align-items: center; align-self: center; }
  .header-right > :last-child { margin-right: 0; }

  .designed-for-bos {
    display: inline-flex;
    align-items: center;
    margin-left: 1.5rem; /* match wallet space-x-6 ~ 24px */
    text-decoration: none;
    transition: opacity 0.2s ease;
    gap: 0.3rem;
    white-space: nowrap;
  }
  .designed-for-bos:hover { opacity: 0.8; }

  .designed-text {
    font-size: 0.875rem; /* text-sm */
    color: #000000;
    white-space: nowrap;
    transform: translateY(5px);
    line-height: 1;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .bos-logo {
    opacity: 0.9;
    transform: translateY(8px);
    margin-left: -13px;
    color: #000000;
    flex-shrink: 0;
  }
  :global([data-theme='dark']) .designed-text { color: #ffffff; }
  :global([data-theme='dark']) .bos-logo { color: #ffffff; }

  .social-icons { display: inline-flex; align-items: center; gap: 1rem; }

  /* Hide tagline on very small screens to avoid wrapping */
  @media (max-width: 420px) { .designed-for-bos { display: none; } }
  @media (max-width: 720px) {
    .designed-text { font-size: 0.8rem; transform: translateY(4px); }
    .bos-logo { transform: translateY(7px); }
  }

  /* Do not switch to grid/display: contents here; keep simple flex to avoid overlap with announcement bar */

  /* Restore Charms logo visual size like default header */
  :global(.site-title) img.logo, :global(.site-title) img[alt][src] {
    height: var(--sl-logo-height);
    width: auto;
  }
  :global(.site-title) { display: inline-flex; align-items: center; }
  @media (max-width: 720px) {
    :global(.site-title) img.logo, :global(.site-title) img[alt][src] { height: 44px; }
  }
</style>
